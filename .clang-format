# ============================================================================
# CẤU HÌNH CLANG-FORMAT CHO VNExos Bản Nguyên
# ============================================================================
BasedOnStyle: LLVM
Language: Cpp

# Chuẩn C++ mới nhất
Standard: Latest

# ----------------------------------------------------------------------------
# Khoảng đệm và khoảng cách
# ----------------------------------------------------------------------------
IndentWidth: 2
TabWidth: 2
UseTab: Never
ColumnLimit: 0
ContinuationIndentWidth: 4

# Xóa khoảng đệm cho các namespace
NamespaceIndentation: None

# ----------------------------------------------------------------------------
# Con trỏ
# ----------------------------------------------------------------------------
PointerAlignment: Left

# ----------------------------------------------------------------------------
# Dấu ngoặc
# ----------------------------------------------------------------------------
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: false
  AfterClass: false
  AfterControlStatement: Always
  AfterEnum: false
  AfterFunction: true
  AfterNamespace: false
  AfterObjCDeclaration: true
  AfterStruct: true
  AfterUnion: false
  AfterExternBlock: false
  BeforeCatch: false
  BeforeElse: false
  IndentBraces: false
  SplitEmptyFunction: true
  SplitEmptyRecord: true
  SplitEmptyNamespace: true

# ----------------------------------------------------------------------------
# Căn hàng
# ----------------------------------------------------------------------------
# Căn thẳng hàng các dấu bằng (=) khi gán giá trị
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  AlignCompound: true
  PadOperators: true

# ÉP CĂN THẲNG HÀNG CÁC ĐỊNH NGHĨA #define (MACRO) TOÀN DIỆN
AlignConsecutiveMacros:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false

# ÉP CĂN THẲNG HÀNG TÊN BIẾN TRONG STRUCT/CLASS/KHAI BÁO
AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false

# Căn thẳng hàng các ghi chú (//) ở cuối dòng
AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 1

# ----------------------------------------------------------------------------
# Các chứng năng C++ hiện đại
# ----------------------------------------------------------------------------
AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: Inline
AllowShortLoopsOnASingleLine: false
AllowShortIfStatementsOnASingleLine: WithoutElse

AllowShortLambdasOnASingleLine: All

# ----------------------------------------------------------------------------
# Dấu cách và khoảng cách
# ----------------------------------------------------------------------------
SpaceBeforeParens: ControlStatements
SpaceInEmptyBlock: false
SpaceInEmptyParentheses: false
SpacesInConditionalStatement: false
SpacesInContainerLiterals: false
SpacesInParentheses: false
SpacesInSquareBrackets: false

SpacesInAngles: Never

# ----------------------------------------------------------------------------
# Sắp xếp include theo bảng chữ cái cho sạch sẽ
# ----------------------------------------------------------------------------
SortIncludes: CaseSensitive

ConstructorInitializerAllOnOneLineOrOnePerLine: true
AllowAllConstructorInitializersOnNextLine: true
